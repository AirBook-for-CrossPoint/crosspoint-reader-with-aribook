{
  "schema": 1,
  "id": "super-minimal",
  "name": "Super Minimal",
  "description": "Centered text-only home menu with Continue Reading as the first item and no cover area.",
  "inherits": "lyra",
  "metrics": {
    "headerHeight": 64,
    "homeTopPadding": 88,
    "homeCoverHeight": 0,
    "homeCoverTileHeight": 0,
    "homeRecentBooksCount": 1,
    "homeContinueReadingInMenu": true,
    "homeMenuTopOffset": 12,
    "menuRowHeight": 42,
    "menuSpacing": 6,
    "contentSidePadding": 32
  },
  "components": {
    "homeRecents": {
      "type": "none"
    },
    "homeMenu": {
      "font": "ui10",
      "style": "regular",
      "centeredText": true,
      "showIcons": false,
      "drawPanel": false,
      "panelWidth": 360,
      "selectionStyle": "outline",
      "selectionCornerRadius": 6,
      "selectionInset": 18
    },
    "list": {
      "font": "ui10",
      "style": "regular",
      "showIcons": true,
      "textGap": 8,
      "selectionCornerRadius": 6,
      "selectionFill": true,
      "selectionOutline": false,
      "selectedTextInverted": false,
      "selectionInsetX": 0,
      "selectionInsetY": 0,
      "titleOffsetY": 7,
      "subtitleOffsetY": 30,
      "valueOffsetY": 6,
      "subtitleValueOffsetY": 16,
      "iconOffsetY": 10
    },
    "buttonHints": {
      "font": "small",
      "style": "regular",
      "buttonWidth": 80,
      "smallButtonHeight": 15,
      "cornerRadius": 6,
      "fill": true,
      "outline": true,
      "drawEmpty": true,
      "textOffsetY": 7
    }
  },
  "devices": {
    "x3": {
      "constraints": {
        "screenWidth": 480,
        "screenHeight": 800,
        "frontButtons": 4,
        "sideButtons": "up-down"
      }
    },
    "x4": {
      "constraints": {
        "screenWidth": 480,
        "screenHeight": 800,
        "frontButtons": 0,
        "sideButtons": "up-down"
      }
    }
  },
  "extensions": {
    "crossink": {
      "reference": "src/components/themes/minimal"
    }
  }
}
